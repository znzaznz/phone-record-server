# 复制为 .env 后填写真值（勿把 .env 提交到 Git）
# cp .env.example .env

# -----------------------------------------------------------------------------
# 转写服务二选一：siliconflow（默认）| dashscope（阿里云百炼）
# -----------------------------------------------------------------------------
STT_PROVIDER=siliconflow

# -----------------------------------------------------------------------------
# SiliconFlow（STT_PROVIDER=siliconflow 时使用）
# 文档: https://docs.siliconflow.cn/
# -----------------------------------------------------------------------------
STT_API_KEY=
# STT_BASE_URL=https://api.siliconflow.cn/v1
# STT_MODEL=TeleAI/TeleSpeechASR

# 长音频切块（秒），0=整文件一次上传。仅 SiliconFlow 路径使用；百炼整段一次任务会忽略切块
# STT_CHUNK_SECONDS=300
# STT_CHUNK_MERGE_TAIL_SECONDS=2
# STT_CHUNK_OVERLAP_SECONDS=5

# -----------------------------------------------------------------------------
# 阿里云百炼 DashScope / Fun-ASR（STT_PROVIDER=dashscope 时使用）
# Key: https://help.aliyun.com/zh/model-studio/get-api-key
# 密钥可只填 DASHSCOPE_API_KEY，或只填 STT_API_KEY（二选一，与 SiliconFlow 共用变量名时请勿混用两家 key）
# -----------------------------------------------------------------------------
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# 国际（新加坡）可改为: https://dashscope-intl.aliyuncs.com
# DASHSCOPE_MODEL=fun-asr
# DASHSCOPE_DIARIZATION_ENABLED=true
# 说话人数量参考（可选，2–100），不设则由模型估计
# DASHSCOPE_SPEAKER_COUNT=2
# DASHSCOPE_POLL_INTERVAL_SECONDS=2
# DASHSCOPE_POLL_TIMEOUT_SECONDS=7200

# -----------------------------------------------------------------------------
# 本机 / 容器内结果目录（默认 shared/output）
# 每个任务产出：{task_id}.md（仅转写成功时）+ {task_id}.<原扩展名> 源音频（成功或失败都会落盘）
# -----------------------------------------------------------------------------
# SHARED_OUTPUT_DIR=shared/output
